# Aunak Core — environment template (copy to .env.local — never commit secrets)

# ── Client (Vite) ─────────────────────────────────────────
# P0: production builds always use proxy — do NOT set PAT in Vercel client env
VITE_USE_AIRTABLE_PROXY=true
VITE_AIRTABLE_BASE_ID=appaGfKj4vYhMw0cb
VITE_AIRTABLE_STUDENTS_TABLE_ID=tblzYmBGmCxx2vdcr
VITE_AIRTABLE_DAILY_SESSIONS_TABLE_ID=tbl3mlewMLvqp6AXB

# Dev-only direct Airtable (local .env.local — never in production Vercel)
# VITE_AIRTABLE_PAT=pat...

# Ghost Mirror Realtime (Ably) — server key required for publish; optional for local child subscribe tests
# ABLY_API_KEY=appId.keyId:secret

# B2G ministry anonymization HMAC salt (server-only)
# B2G_HMAC_SALT=your-sovereign-salt

# Dev-only master bypass override (disabled automatically in production builds)
# VITE_AUNAK_MASTER_KEY=

# Tawasul sandbox — NEVER set on sovereign production (aunak.vercel.app opens Core at /)
# Use /tawasul path instead. Only enable on Tawasul preview deployments.
# VITE_TAWASUL_MVP=true

# ── Server (Vercel — no VITE_ prefix) ───────────────────
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appaGfKj4vYhMw0cb
AIRTABLE_STUDENTS_TABLE_ID=tblzYmBGmCxx2vdcr
ABLY_API_KEY=
B2G_HMAC_SALT=
TAP_SECRET_KEY=
ELEVENLABS_API_KEY=
