# Airtable — copy to .env.local (never commit secrets)
# Daily Sessions — copy table ID from Airtable URL (must start with tbl, not the display name)
VITE_AIRTABLE_DAILY_SESSIONS_TABLE_ID=tbl3mlewMLvqp6AXB
# Server-side (Vercel): AIRTABLE_DAILY_SESSIONS_TABLE_ID=tblXXXXXXXXXXXXXX
VITE_AIRTABLE_BASE_ID=appaGfKj4vYhMw0cb
VITE_AIRTABLE_STUDENTS_TABLE_ID=tblzYmBGmCxx2vdcr
VITE_AIRTABLE_SPECIALISTS_TABLE_ID=tblnmcLd5M3U6sErl

# ── Tawasul MVP (branch Tawasul_MVP only — separate free Airtable base) ──
# VITE_TAWASUL_MVP=true
# VITE_AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
# VITE_AIRTABLE_STUDENTS_TABLE_ID=tblXXXXXXXXXXXXXX
# VITE_AIRTABLE_SPECIALISTS_TABLE_ID=tblXXXXXXXXXXXXXX
# VITE_AIRTABLE_DAILY_SESSIONS_TABLE_ID=tblXXXXXXXXXXXXXX
# AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
# AIRTABLE_API_KEY=pat...
# AIRTABLE_DAILY_SESSIONS_TABLE_ID=tblXXXXXXXXXXXXXX
# See docs/TAWASUL_MVP.md

# VITE_AIRTABLE_PAT=pat...
# Optional cloud TTS for Summer Academy (ElevenLabs)
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_VOICE_ID=optional_voice_id

# Tap Payments — online checkout (server-only, never VITE_*)
# MOCK_PAYMENTS=true  — force mock mode even with Tap key (Preview QA)
# Preview without TAP_SECRET_KEY auto-enables mock checkout + webhook simulation

# Sovereign dev master — skips anti-spoof duplicate-face block during QA (default: AUNAK-MASTER-2026)
# URL: ?master=AUNAK-MASTER-2026
# VITE_AUNAK_MASTER_KEY=AUNAK-MASTER-2026
